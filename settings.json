{
  // 인덱싱할 디렉터리 (복수 지정 가능). 상대 경로는 이 settings.json 위치 기준.
  // Windows 경로는 백슬래시를 두 개(\\) 쓰거나 슬래시(/)를 쓰세요. 예: "D:\\MyMusic" 또는 "D:/MyMusic"
  "musicSearch.searchDirectories": [
    "./MyMusic"
  ],

  // 인덱싱 제외 — VS Code files.exclude 형식의 { glob: bool } 맵
  "musicSearch.exclude": {
    "**/*.jpg": true, // 앨범 아트 제외
    "**/*.db": true,
    "**/*.ini": true
  }
}
